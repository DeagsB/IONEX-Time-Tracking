# Copy this file to backup-config.env and fill in your values.
# backup-config.env is gitignored - never commit it.
#
# Free tier: Supabase Dashboard backup is not available; use these scripts instead.
#
# Option A: Direct database connection (best - true full backup via pg_dump: schema + all data the DB user can read)
# Get from: Supabase Dashboard -> Project Settings -> Database -> Connection string (URI).
# Use the direct host (db.PROJECT_REF.supabase.co) on port 5432 if the pooler gives errors with pg_dump.
# Replace [YOUR-PASSWORD] with your database password.
SUPABASE_DB_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[project-ref].supabase.co:5432/postgres
#
# Option B: API credentials (no pg_dump needed - uses Node.js backup)
# Get from: Supabase Dashboard -> Project Settings -> API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service_role-key-here
